# DeepSeek API 配置
# 复制此文件为 .env 并填入你的真实密钥
VITE_DEEPSEEK_API_KEY=sk-your-api-key-here

# DeepSeek API 请求地址
VITE_DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# DeepSeek 模型名称
VITE_DEEPSEEK_MODEL=deepseek-chat

# 高德地图 Web 服务 API Key（用于天气查询）
# 申请地址: https://console.amap.com/dev/key/app
VITE_AMAP_KEY=your-amap-key-here
